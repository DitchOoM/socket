language = Objective-C
package = com.ditchoom.socket.quic.nwudp
headers = nw_udp_helpers.h
headerFilter = nw_udp_helpers.h
linkerOpts = -framework Network -framework Foundation
---
#include <Network/Network.h>
#include <Foundation/Foundation.h>
#include <sys/socket.h>

// Decompose an nw_error_t into K/N-safe scalars (see nw_helpers.h's describe_nw_error).
static void nw_udp_describe_error(nw_error_t _Nullable error,
    int32_t *out_domain, int32_t *out_code, NSString * __autoreleasing *out_desc)
{
    if (error == NULL) { *out_domain = 0; *out_code = 0; *out_desc = nil; return; }
    int code = nw_error_get_error_code(error);
    nw_error_domain_t domain = nw_error_get_error_domain(error);
    if (domain == nw_error_domain_posix) {
        *out_domain = 1; *out_code = code;
        *out_desc = [NSString stringWithFormat:@"POSIX error %d: %s", code, strerror(code)];
    } else if (domain == nw_error_domain_dns) {
        *out_domain = 2; *out_code = code;
        *out_desc = [NSString stringWithFormat:@"DNS error %d", code];
    } else if (domain == nw_error_domain_tls) {
        *out_domain = 3; *out_code = code;
        *out_desc = [NSString stringWithFormat:@"TLS error %d", code];
    } else {
        *out_domain = 4; *out_code = code;
        *out_desc = [NSString stringWithFormat:@"Network error domain=%d code=%d", (int)domain, code];
    }
}

nw_connection_t _Nullable nw_udp_create(const char * _Nonnull host, const char * _Nonnull port)
{
    nw_endpoint_t endpoint = nw_endpoint_create_host(host, port);
    if (endpoint == NULL) return NULL;
    // DISABLE_PROTOCOL on the TLS configure slot = plain UDP (quiche owns QUIC's crypto). Default UDP
    // configuration otherwise.
    nw_parameters_t params = nw_parameters_create_secure_udp(
        NW_PARAMETERS_DISABLE_PROTOCOL,
        NW_PARAMETERS_DEFAULT_CONFIGURATION);
    return nw_connection_create(endpoint, params);
}

void nw_udp_set_state_handler(nw_connection_t _Nonnull conn, nw_udp_state_handler_t _Nonnull handler)
{
    nw_connection_set_state_changed_handler(conn,
        ^(nw_connection_state_t state, nw_error_t _Nullable error) {
            int32_t domain = 0, code = 0; NSString *desc = nil;
            nw_udp_describe_error(error, &domain, &code, &desc);
            handler((int32_t)state, domain, code, desc);
        });
}

void nw_udp_start(nw_connection_t _Nonnull conn)
{
    nw_connection_set_queue(conn, dispatch_get_global_queue(QOS_CLASS_USER_INITIATED, 0));
    nw_connection_start(conn);
}

void nw_udp_cancel(nw_connection_t _Nonnull conn)
{
    nw_connection_cancel(conn);
}

static int32_t nw_udp_copy_endpoint_addr(nw_endpoint_t _Nullable ep, void * _Nonnull out, int32_t cap)
{
    if (ep == NULL) return -1;
    const struct sockaddr *sa = nw_endpoint_get_address(ep);
    if (sa == NULL) return -1;
    int len = sa->sa_len; // BSD/Darwin sockaddr carries its own length in byte 0
    if (len <= 0 || len > cap) return -1;
    memcpy(out, sa, (size_t)len);
    return (int32_t)len;
}

int32_t nw_udp_copy_local_sockaddr(nw_connection_t _Nonnull conn, void * _Nonnull out, int32_t cap)
{
    nw_path_t path = nw_connection_copy_current_path(conn);
    if (path == NULL) return -1;
    nw_endpoint_t ep = nw_path_copy_effective_local_endpoint(path);
    return nw_udp_copy_endpoint_addr(ep, out, cap);
}

int32_t nw_udp_copy_remote_sockaddr(nw_connection_t _Nonnull conn, void * _Nonnull out, int32_t cap)
{
    nw_path_t path = nw_connection_copy_current_path(conn);
    if (path == NULL) return -1;
    nw_endpoint_t ep = nw_path_copy_effective_remote_endpoint(path);
    return nw_udp_copy_endpoint_addr(ep, out, cap);
}

void nw_udp_receive(nw_connection_t _Nonnull conn, nw_udp_receive_handler_t _Nonnull handler)
{
    nw_connection_receive_message(conn,
        ^(dispatch_data_t _Nullable content, nw_content_context_t _Nullable context,
          bool is_complete, nw_error_t _Nullable error) {
            if (error != NULL) {
                int32_t domain = 0, code = 0; NSString *desc = nil;
                nw_udp_describe_error(error, &domain, &code, &desc);
                handler(nil, domain, code);
                return;
            }
            // content == nil on a final empty message (peer/cancel) — surfaced to Kotlin as a closed
            // channel (nil + code 0). dispatch_data_t is toll-free bridged to NSData; .bytes is
            // contiguous after the implicit flatten.
            handler((NSData *)content, 0, 0);
        });
}

void nw_udp_send(nw_connection_t _Nonnull conn, const void * _Nonnull bytes, int32_t len,
    nw_udp_send_handler_t _Nonnull handler)
{
    dispatch_data_t data = dispatch_data_create(bytes, (size_t)len,
        dispatch_get_global_queue(QOS_CLASS_DEFAULT, 0), DISPATCH_DATA_DESTRUCTOR_DEFAULT);
    nw_connection_send(conn, data, NW_CONNECTION_DEFAULT_MESSAGE_CONTEXT, true,
        ^(nw_error_t _Nullable error) {
            int32_t domain = 0, code = 0; NSString *desc = nil;
            nw_udp_describe_error(error, &domain, &code, &desc);
            handler(domain, code);
        });
}
