language = C
package = com.ditchoom.socket.udp.linux

# Linux UDP datagram substrate: io_uring async I/O over plain POSIX UDP sockets.
#
# Deliberately TLS-free — unlike root :socket's LinuxSockets.def (which links -lssl -lcrypto for
# K/N TLS), UDP needs neither OpenSSL nor BoringSSL. Only liburing + libc.
#
# Dependency: liburing static lib, reused from root :socket's libs/liburing/linux-<arch>/ (built by
# root's buildLiburing<Arch> task). libraryPaths/staticLibraries are injected by the generate task in
# build.gradle.kts (which rewrites the linkerOpts.linux line below into static-library embedding).

headers = sys/socket.h sys/types.h netinet/in.h netinet/ip.h arpa/inet.h netdb.h unistd.h fcntl.h errno.h string.h stdint.h net/if.h ifaddrs.h sys/eventfd.h poll.h sys/select.h sys/time.h liburing.h

compilerOpts.linux = -D_GNU_SOURCE -D_POSIX_C_SOURCE=200809L

# Rewritten by generateUdpSocketsDef<Arch> into libraryPaths + staticLibraries + -lpthread.
linkerOpts.linux = -luring -lpthread

---

// --- sockaddr union wrappers ---
// glibc's getsockname/getpeername/bind take the __SOCKADDR_ARG transparent union, which Kotlin/Native
// cannot express. These thin wrappers take raw struct sockaddr* so K/N can call them (same technique
// as root :socket's LinuxSockets.def).

static inline int socket_getsockname(int sockfd, struct sockaddr *addr, socklen_t *addrlen) {
    return getsockname(sockfd, addr, addrlen);
}

static inline int socket_getpeername(int sockfd, struct sockaddr *addr, socklen_t *addrlen) {
    return getpeername(sockfd, addr, addrlen);
}

static inline int socket_bind(int sockfd, const struct sockaddr *addr, socklen_t addrlen) {
    return bind(sockfd, addr, addrlen);
}

static inline int socket_connect(int sockfd, const struct sockaddr *addr, socklen_t addrlen) {
    return connect(sockfd, addr, addrlen);
}

// --- cmsg macro wrappers ---
// CMSG_FIRSTHDR/NXTHDR/SPACE/LEN/DATA are function-like C macros; cinterop binds only
// functions/typedefs/enums, not macros. Wrap them as static inline functions so the Kotlin control
// plane (ECN / TTL / IP_PKTINFO ancillary data) can walk and build cmsgs. `struct cmsghdr` itself is
// a plain struct and binds directly.

static inline struct cmsghdr *cmsg_firsthdr(struct msghdr *msg) {
    return CMSG_FIRSTHDR(msg);
}

static inline struct cmsghdr *cmsg_nxthdr(struct msghdr *msg, struct cmsghdr *cmsg) {
    return CMSG_NXTHDR(msg, cmsg);
}

static inline size_t cmsg_space(size_t length) {
    return CMSG_SPACE(length);
}

static inline size_t cmsg_len(size_t length) {
    return CMSG_LEN(length);
}

static inline unsigned char *cmsg_data(struct cmsghdr *cmsg) {
    return CMSG_DATA(cmsg);
}

// --- IP multicast control plane (POSIX setsockopt) ---
// Struct-free-at-the-Kotlin-boundary helpers, identical in shape to the Apple module's nw_udp_helpers.h:
// the group is passed as a filled `sockaddr` (from LinuxSocketAddress.writeSockaddr) and the C side pulls
// in_addr / in6_addr out by family. The interface is named by a network-order IPv4 s_addr [iface_v4_be]
// (`0` = INADDR_ANY, for IPv4) OR an index [ifindex] (`0` = default, for IPv6). Each returns 0 on success,
// -1 on failure (errno set) — no multicast struct crosses the cinterop boundary.

static inline int socket_mc_join(int fd, const struct sockaddr *group, uint32_t iface_v4_be, unsigned int ifindex) {
    if (group->sa_family == AF_INET) {
        struct ip_mreq mreq;
        memset(&mreq, 0, sizeof(mreq));
        mreq.imr_multiaddr = ((const struct sockaddr_in *)group)->sin_addr;
        mreq.imr_interface.s_addr = iface_v4_be;
        return setsockopt(fd, IPPROTO_IP, IP_ADD_MEMBERSHIP, &mreq, sizeof(mreq));
    } else if (group->sa_family == AF_INET6) {
        struct ipv6_mreq mreq;
        memset(&mreq, 0, sizeof(mreq));
        mreq.ipv6mr_multiaddr = ((const struct sockaddr_in6 *)group)->sin6_addr;
        mreq.ipv6mr_interface = ifindex;
        return setsockopt(fd, IPPROTO_IPV6, IPV6_JOIN_GROUP, &mreq, sizeof(mreq));
    }
    errno = EAFNOSUPPORT;
    return -1;
}

static inline int socket_mc_leave(int fd, const struct sockaddr *group, uint32_t iface_v4_be, unsigned int ifindex) {
    if (group->sa_family == AF_INET) {
        struct ip_mreq mreq;
        memset(&mreq, 0, sizeof(mreq));
        mreq.imr_multiaddr = ((const struct sockaddr_in *)group)->sin_addr;
        mreq.imr_interface.s_addr = iface_v4_be;
        return setsockopt(fd, IPPROTO_IP, IP_DROP_MEMBERSHIP, &mreq, sizeof(mreq));
    } else if (group->sa_family == AF_INET6) {
        struct ipv6_mreq mreq;
        memset(&mreq, 0, sizeof(mreq));
        mreq.ipv6mr_multiaddr = ((const struct sockaddr_in6 *)group)->sin6_addr;
        mreq.ipv6mr_interface = ifindex;
        return setsockopt(fd, IPPROTO_IPV6, IPV6_LEAVE_GROUP, &mreq, sizeof(mreq));
    }
    errno = EAFNOSUPPORT;
    return -1;
}

static inline int socket_mc_set_ttl(int fd, int ipv6, int ttl) {
    int v = ttl; // Linux IP_MULTICAST_TTL / IPV6_MULTICAST_HOPS take an int
    if (ipv6) return setsockopt(fd, IPPROTO_IPV6, IPV6_MULTICAST_HOPS, &v, sizeof(v));
    return setsockopt(fd, IPPROTO_IP, IP_MULTICAST_TTL, &v, sizeof(v));
}

static inline int socket_mc_set_loop(int fd, int ipv6, int on) {
    int v = on;
    if (ipv6) return setsockopt(fd, IPPROTO_IPV6, IPV6_MULTICAST_LOOP, &v, sizeof(v));
    return setsockopt(fd, IPPROTO_IP, IP_MULTICAST_LOOP, &v, sizeof(v));
}

static inline int socket_mc_set_if(int fd, int ipv6, uint32_t iface_v4_be, unsigned int ifindex) {
    if (ipv6) {
        unsigned int idx = ifindex;
        return setsockopt(fd, IPPROTO_IPV6, IPV6_MULTICAST_IF, &idx, sizeof(idx));
    }
    struct in_addr a;
    a.s_addr = iface_v4_be;
    return setsockopt(fd, IPPROTO_IP, IP_MULTICAST_IF, &a, sizeof(a));
}

static inline unsigned int socket_if_index(const char *name) {
    return if_nametoindex(name); // 0 on failure
}

static inline uint32_t socket_if_ipv4_be(unsigned int ifindex) {
    if (ifindex == 0) return 0;
    char name[IF_NAMESIZE];
    if (if_indextoname(ifindex, name) == NULL) return 0;
    struct ifaddrs *ifap = NULL;
    if (getifaddrs(&ifap) != 0) return 0;
    uint32_t result = 0;
    struct ifaddrs *ifa;
    for (ifa = ifap; ifa != NULL; ifa = ifa->ifa_next) {
        if (ifa->ifa_addr == NULL) continue;
        if (ifa->ifa_addr->sa_family != AF_INET) continue;
        if (strcmp(ifa->ifa_name, name) != 0) continue;
        result = ((struct sockaddr_in *)ifa->ifa_addr)->sin_addr.s_addr;
        break;
    }
    freeifaddrs(ifap);
    return result;
}
