# Single source of truth for harness host/ports.
# Read by the `generateHarnessConfig` Gradle task → HarnessConfig.kt
# (visible to every test source set). Edit ports here, not in code.
#
# Ports are bound to 127.0.0.1 on the host. Pinned, not dynamic, so all
# platforms see identical numbers regardless of how the stack is launched.

HARNESS_HOST=127.0.0.1

# L0 — plain TCP echo (socat EXEC:cat)
ECHO_PORT=14000

# L0 — HTTP/1.1 (nginx)
HTTP_PORT=14080

# L6 — TLS cert matrix. One container, one port per cert scenario (see
# test-harness/tls/conf.d/default.conf and test-harness/tls/gen-certs.sh).
TLS_VALID_PORT=14443
TLS_SELF_SIGNED_PORT=14453
TLS_EXPIRED_PORT=14463
TLS_WRONG_HOST_PORT=14473
TLS_UNTRUSTED_PORT=14483

# Sixth TLS vhost — same valid cert as 14443 but negotiates *only* TLS 1.3
# (no 1.2 fallback). Used by `tlsHarnessFirstReadReturnsData` to lock the
# first-read-after-write assertion onto a handshake that can't downgrade.
TLS_TLS13_PORT=14493

# L4 — toxiproxy (Phase 3). Control API + three proxies, one per upstream.
# Proxies are POSTed at test-setup time by the Toxiproxy helper in
# commonJvmTest; this file only pins the ports.
TOXIPROXY_API_PORT=8474
TOXIPROXY_ECHO_PORT=15000
TOXIPROXY_HTTP_PORT=15080
TOXIPROXY_TLS_PORT=15443

# Dedicated echo proxy for :socket-testsuite's withNetworkHarness impairments
# (`suite-echo` in the toxiproxy table). Separate name AND port from
# TOXIPROXY_ECHO_PORT so the root module's tests and the testsuite's — which run
# in parallel Gradle test tasks against the same toxiproxy — never mutate each
# other's proxy state (toxics, enable/disable).
TOXIPROXY_SUITE_ECHO_PORT=15900

# L3 — netem blackhole. Listener that accepts SYNs but drops all egress packets
# (tc qdisc netem loss 100%). Replaces the magic `10.255.255.1` non-routable IP
# in connect-timeout tests with a deterministic local endpoint.
#
# We connect to the pinned docker-bridge IP rather than 127.0.0.1 because
# docker-proxy on the loopback publish would complete the connect()
# locally and defeat the blackhole semantics. See the netem-blackhole
# service in docker-compose.yml for the full rationale.
NETEM_BLACKHOLE_HOST=172.30.0.99
NETEM_BLACKHOLE_PORT=14999

# L4 — Deterministic peer-close sidecar. Python listener that calls
# setsockopt(SO_LINGER, on=1, linger=0) + close() on the accepted FD. Any byte
# from the client triggers the close. Used by pendingReadDuringPeerReset to
# force a deterministic connection-loss signal on the read path without
# toxiproxy.
#
# Published on 127.0.0.1 (host) → docker-proxy. The proxy converts the
# server-side RST into a graceful FIN, but FIN still surfaces as
# SocketClosedException.EndOfStream which satisfies the parent-class
# assertion. The bridge IP approach (used by NETEM_BLACKHOLE_HOST) was tried
# but exhibited one-way-path issues on GH ubuntu-24.04 runners for small
# writes — see docker-compose.yml `rst:` for the rationale.
RST_PORT=14998

# L7 — QUIC echo server (Phase 4). Container wraps QuicEchoTestServer; see
# test-harness/quic-echo/Dockerfile and :socket-quic:quicEchoJar.
QUIC_ECHO_PORT=14433

# L1 — UDP datagram echo (socat UDP-RECVFROM,fork EXEC:cat). The datagram analogue of
# ECHO_PORT: a clean round-trip endpoint for :socket-udp's UdpSocket, and the upstream
# udp-toxi forwards to. See test-harness/udp-echo/Dockerfile.
UDP_ECHO_PORT=14434

# L4 — udp-toxi relay (RFC_UNIFIED_NETWORK_TEST_HARNESS §5). Two planes: an HTTP/REST
# CONTROL plane over TCP (toxiproxy-shaped, provisions a FaultSchedule per relay) and a
# per-datagram UDP DATA plane it impairs+forwards. JVM/Kotlin sidecar driving the same
# testkit ImpairmentEngine the Tier-A pipe does (A⇄C parity). See
# test-harness/udp-toxi/Dockerfile and :socket-testsuite:udpToxiJar.
UDP_TOXI_API_PORT=8475

# Dedicated udp-toxi relay data port for :socket-testsuite's withNetworkHarness impairedUdp
# (the `suite-udp` relay). Separate name AND port from any relay a parallel test-task family
# provisions, so their per-relay schedules never mutate each other (the suite-echo lesson,
# applied to datagrams).
UDP_TOXI_SUITE_PORT=14435

# L8 — W6 harness controller (RFC_DETERMINISTIC_SIMULATION §7). Serves
# `GET /health` + `GET /describe` (the scenario manifest) so consumer tests
# discover endpoints via `withNetworkHarness` in :socket-testsuite instead of
# reading this file. The compose service passes this whole file into the
# container via `env_file`, which is how the manifest mirrors these values.
CONTROLLER_PORT=14100
