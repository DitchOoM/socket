# Single source of truth for harness host/ports.
# Read by the `generateHarnessConfig` Gradle task → HarnessConfig.kt
# (visible to every test source set). Edit ports here, not in code.
#
# Ports are bound to 127.0.0.1 on the host. Pinned, not dynamic, so all
# platforms see identical numbers regardless of how the stack is launched.

HARNESS_HOST=127.0.0.1

# L0 — plain TCP echo (socat EXEC:cat)
ECHO_PORT=14000

# L0 — HTTP/1.1 (nginx)
HTTP_PORT=14080

# Reserved for later phases (commented out until those services land):
# TLS_VALID_PORT=14443
# TLS_SELF_SIGNED_PORT=14453
# TLS_EXPIRED_PORT=14463
# TLS_WRONG_HOST_PORT=14473
# TLS_UNTRUSTED_PORT=14483
# TLS_TLS13_PORT=14493
# TOXIPROXY_API_PORT=8474
# TOXIPROXY_ECHO_PORT=15000
# QUIC_ECHO_PORT=14433
