libs/
# Android JNI shims (built by buildAndroidNativeLibs task)
socket-quic/src/androidMain/jniLibs/*/*.so
socket-quic/src/androidMain/jniLibs/*/.built-*
socket-quic-quiche/src/androidMain/jniLibs/*/*.so
socket-quic-quiche/src/androidMain/jniLibs/*/.built-*

