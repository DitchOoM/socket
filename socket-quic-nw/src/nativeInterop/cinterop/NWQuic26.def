language = Objective-C
package = com.ditchoom.socket.quic.nwquic26
headers = NWQuic26-Swift.h
headerFilter = NWQuic26-Swift.h
# System frameworks the Swift shim links against (NetworkConnection<QUIC>, SecPKCS12Import, CryptoKit
# SHA-256 for the cert-hash pin). The archive's LC_LINKER_OPTION autolink requests these too, but list
# them explicitly (as NWQuicHelpers.def does) so the K/N link resolves them regardless.
linkerOpts = -framework Network -framework Security -framework CryptoKit -framework Foundation -framework CoreFoundation
# NWQuic26-Swift.h is generated by swiftc (the buildNWQuic26Swift<target> Gradle task) into
# build/nwquic26/<target>/; includeDirs is supplied per-target in build.gradle.kts. The static
# archive (libNWQuic26.a) + Swift runtime are linked via binaries{} linkerOpts there too.
